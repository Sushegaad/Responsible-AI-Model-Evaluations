# RAI Eval — Environment Variables Template
# Copy this file to .env and fill in your API keys:
#   cp .env.template .env
#
# IMPORTANT: Never commit .env to git — it's already in .gitignore.

# ── Required: API Keys ───────────────────────────────────────────────────────
# Anthropic key is REQUIRED for the neural judge (Claude Haiku) regardless of
# which models you are testing. It is also used to test Claude models.
ANTHROPIC_API_KEY=sk-ant-...

# Required only when testing OpenAI models (GPT-4o, GPT-4o Mini)
OPENAI_API_KEY=sk-...

# Required only when testing Google models (Gemini 2.0 Flash, Gemini 1.5 Pro)
GOOGLE_API_KEY=...

# Required only when testing Meta/Llama models via Together AI
TOGETHER_API_KEY=...

# ── Optional: Evaluation Tuning ──────────────────────────────────────────────
# Number of RedBench samples to evaluate per model (default: 500, ~$29/week full run)
# Use 50 for a quick smoke test (~$3), or 100 for ~$6/week
REDEVAL_NUM_SAMPLES=500

# Output directory for weekly results (default: data/weekly)
REDEVAL_OUTPUT_DIR=data/weekly

# Log verbosity: DEBUG | INFO | WARNING | ERROR (default: INFO)
REDEVAL_LOG_LEVEL=INFO
